# ==========================================
# Skin Factory Backend - Переменные окружения
# ==========================================

# --- Основное ---
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://*.vercel.app

# --- База данных PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/skin_factory?schema=public

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=SkinFactoryArBot
TELEGRAM_WEB_APP_URL=http://localhost:5173

# --- Администраторы (Telegram ID через запятую) ---
ADMIN_IDS=777777777,123456789

# --- Платежи (опционально) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Steam API (опционально) ---
STEAM_API_KEY=
STEAM_WEB_API_KEY=

# --- Redis (опционально) ---
REDIS_URL=redis://localhost:6379

# --- Логирование ---
LOG_LEVEL=info

# --- Безопасность ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12

# --- Email (опционально) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@skinfactory.com

# --- CDN (опционально) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# --- Приложение ---
APP_NAME=Skin Factory
APP_VERSION=2.0.0
SUPPORT_EMAIL=support@skinfactory.com
